# Claude API
ANTHROPIC_API_KEY=your_anthropic_api_key

# Meta / Instagram
META_APP_ID=your_meta_app_id
META_APP_SECRET=your_meta_app_secret
META_ACCESS_TOKEN=your_long_lived_access_token
INSTAGRAM_BUSINESS_ACCOUNT_ID=your_instagram_business_account_id

# YouTube
YOUTUBE_CHANNEL_NAME=MASTERING MONEY
YOUTUBE_VIDEO_DURATION=30
YOUTUBE_CATEGORY_ID=22
# OAuth client_secret.json goes in data/client_secret.json
# Token is auto-generated at data/youtube_token.json after first auth

# Email notifications (optional - for weekly summaries)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
NOTIFY_EMAIL=your_email@gmail.com

# Timezone
TIMEZONE=America/New_York

# Image hosting (Instagram only - YouTube uses direct upload)
BASE_URL=http://localhost:5000
